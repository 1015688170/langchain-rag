APP_NAME=LangChain RAG API
APP_VERSION=0.1.0
API_PREFIX=/api
CORS_ALLOW_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# local smoke-test defaults: no network, no real semantic quality
LLM_PROVIDER=echo
EMBEDDING_PROVIDER=hash

# nexus providers
NEXUS_API_KEY=
NEXUS_CHAT_API_URL=
NEXUS_EMBEDDING_API_URL=
NEXUS_CHAT_MODEL=gpt-4o

# openai-compatible providers
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# vector store
VECTORSTORE_PATH=./data/vectorstore.json

# ingestion / retrieval
UPLOAD_DIR=./data/uploads
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5
MIN_RELEVANCE_SCORE=0.0

# reranker, reserved for the next retrieval phase
RERANKER_PROVIDER=none
RERANKER_MODEL_PATH=/opt/swp-models/bge-reranker-v2-m3
RERANKER_TOP_N=5
